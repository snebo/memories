generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum TranscriptStatus {
  pending
  processing
  completed
  failed
}

model Transcript {
  id          String           @id @default(uuid())
  content     String
  contentHash String           @unique
  status      TranscriptStatus @default(pending)
  createdAt   DateTime         @default(now())
}
