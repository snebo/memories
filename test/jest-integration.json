{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": "test/integration/.+\\.integration-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@prisma/generated$": "<rootDir>/src/generated/prisma/client",
    "^@prisma/generated/(.+)$": "<rootDir>/src/generated/prisma/$1",
    "^(\\.{1,2}\\/.+)\\.js$": "$1"
  },
  "testTimeout": 30000
}
