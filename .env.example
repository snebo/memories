# PostgreSQL
POSTGRES_USER=memories
POSTGRES_PASSWORD=memories
POSTGRES_DB=memories

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=memories

# LLM provider — set to "openai" or "gemini"
LLM_PROVIDER=openai

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-4o

# Google Gemini (used when LLM_PROVIDER=gemini)
GEMINI_API_KEY=replace-me
GEMINI_MODEL=gemini-2.0-flash

# App
PORT=3000
DATABASE_URL=postgresql://memories:memories@postgres:5432/memories
REDIS_URL=redis://redis:6379
MINIO_ENDPOINT=http://minio:9000